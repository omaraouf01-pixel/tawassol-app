rules_version = '2';

// ════════════════════════════════════════════════════════════════
//  Firestore Security Rules — TAWASSOL
//  Version: v3.1 — Audit-Hardened (2026-05-15)
//  Build-tag: TWSL-RULES-20260515-A
// ════════════════════════════════════════════════════════════════
//  Stratégie hybride :
//   - Opérations sensibles (création groupe, modération admin, notifs)
//     passent par API routes (firebase-admin → bypass).
//   - Opérations temps-réel (chat, posts, join-requests) → client.
//
//  Changements v3 :
//   1. /notifications.create  → SERVER-ONLY (anti-spam).
//   2. /messages.update       → anti-bypass : un membre ne peut PAS
//      ajouter `fileUrl` après coup (le statut doit rester pending).
//   3. /messages.create       → bloque `moderationStatus: approved`
//      si l'auteur n'est pas overseer.
//   4. Helpers defensifs préservés (exists + .get(default)).
//   5. Default-deny final intact.
// ════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── 🛠️ HELPERS (defensive) ─────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().get('role', '') == 'admin';
    }

    function groupExists(groupId) {
      return groupId is string
        && groupId.size() > 0
        && exists(/databases/$(database)/documents/groups/$(groupId));
    }

    function groupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function isMember(groupId) {
      return isSignedIn()
        && groupExists(groupId)
        && (request.auth.uid in groupData(groupId).get('members', []));
    }

    function isGroupLeader(groupId) {
      return isSignedIn()
        && groupExists(groupId)
        && groupData(groupId).get('leaderId', '') == request.auth.uid;
    }

    function canOverseeGroup(groupId) {
      return isAdmin() || isGroupLeader(groupId);
    }

    // Pour /messages : un overseer (admin OU leader) du groupe ciblé.
    function isOverseerOfRequestGroup() {
      return isAdmin()
          || isGroupLeader(request.resource.data.get('groupId', ''));
    }

    // ─── 1. USERS ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── 2. POSTS (feed public) ────────────────────────────────
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.authorId ||
        isAdmin() ||
        request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['likes', 'commentsCount', 'reactions'])
      );

      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.authorId || isAdmin()
      );

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (
          request.auth.uid == resource.data.authorId || isAdmin()
        );
      }
    }

    // ─── 3. GROUPS ─────────────────────────────────────────────
    //  Création : EXCLUSIVEMENT via API (Admin SDK).
    //  Lecture : signedIn (l'Explore en a besoin).
    //  Update : leader (members/settings) ou admin.
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update: if isAdmin() || isGroupLeader(groupId);
      allow delete: if isAdmin();
    }

    // ─── 4. MESSAGES (collection top-level "messages") ─────────
    //  Champs : uid, groupId, content, fileUrl, fileName, fileType,
    //          senderName, role, moderationStatus, isSystem, createdAt.
    match /messages/{messageId} {

      // ── READ ─────────────────────────────────────────────
      allow read: if isSignedIn() && (
        isAdmin() ||
        isMember(resource.data.get('groupId', '')) ||
        isGroupLeader(resource.data.get('groupId', ''))
      );

      // ── CREATE ───────────────────────────────────────────
      //   1. auteur = UID,
      //   2. groupId valide + auteur a accès,
      //   3. 🛡️ ANTI-BYPASS : membre normal joignant un FICHIER
      //      DOIT le marquer "pending" ; ne peut PAS le poster
      //      directement en "approved".
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.groupId is string
        && request.resource.data.groupId.size() > 0
        && (
          isAdmin() ||
          isGroupLeader(request.resource.data.groupId) ||
          isMember(request.resource.data.groupId)
        )
        && (
          // Cas 1 : pas de fichier → libre
          !('fileUrl' in request.resource.data) ||
          request.resource.data.fileUrl == null
          // Cas 2 : fichier + overseer → ok
          || isOverseerOfRequestGroup()
          // Cas 3 : fichier + membre normal → obligatoirement pending
          || request.resource.data.get('moderationStatus', '') == 'pending'
        );

      // ── UPDATE ───────────────────────────────────────────
      //  • Auteur : peut éditer son texte UNIQUEMENT (pas fileUrl /
      //    moderationStatus → anti-bypass post-création).
      //  • Overseer (leader/admin) : peut tout (approve, reject…).
      allow update: if isSignedIn() && (
        canOverseeGroup(resource.data.get('groupId', '')) ||
        (
          request.auth.uid == resource.data.get('uid', '') &&
          !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['fileUrl', 'fileName', 'fileType',
                                    'moderationStatus', 'uid', 'groupId'])
        )
      );

      // ── DELETE ───────────────────────────────────────────
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.get('uid', '') ||
        canOverseeGroup(resource.data.get('groupId', ''))
      );
    }

    // ─── 5. JOIN-REQUESTS (kebab-case) ─────────────────────────
    match /join-requests/{requestId} {

      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.get('userId', '') ||
        isGroupLeader(resource.data.get('groupId', ''))
      );

      // Création directe par le demandeur (status=pending obligatoire).
      // L'API route (Admin SDK) reste utilisée pour le cas "open access"
      // afin d'ajouter l'utilisateur aux members atomiquement.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.groupId is string
        && request.resource.data.groupId.size() > 0
        && request.resource.data.get('status', '') == 'pending';

      allow update, delete: if isSignedIn() && canOverseeGroup(
        resource.data.get('groupId', '')
      );
    }

    // ─── 6. NOTIFICATIONS ──────────────────────────────────────
    //  🛡️ Création SERVER-ONLY (Admin SDK) pour bloquer le spam.
    match /notifications/{notificationId} {
      allow read, delete: if isSignedIn() && (
        request.auth.uid == resource.data.get('userId', '') || isAdmin()
      );
      allow create: if false;
      // L'utilisateur peut SEULEMENT marquer comme lu.
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.get('userId', '')
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['read', 'isRead']);
    }

    // ─── 7. RESOURCES ──────────────────────────────────────────
    match /resources/{resourceId} {
      allow read: if isSignedIn() && (
        isAdmin() || isMember(resource.data.get('groupId', ''))
      );

      allow create: if isSignedIn()
        && request.resource.data.groupId is string
        && (
          isAdmin() ||
          isGroupLeader(request.resource.data.groupId) ||
          (
            isMember(request.resource.data.groupId)
            && request.resource.data.get('moderationStatus', 'pending') == 'pending'
          )
        );

      allow update, delete: if isSignedIn() && (
        isAdmin() ||
        canOverseeGroup(resource.data.get('groupId', '')) ||
        request.auth.uid == resource.data.get('authorId', '')
      );
    }

    // ─── 8. DEFAULT DENY ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
